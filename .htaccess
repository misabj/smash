# MIME types
AddType application/javascript .js .mjs
AddType text/css .css
AddType image/svg+xml .svg
AddType application/json .json

DirectoryIndex disabled
RewriteEngine On

# Proxy /api and /uploads to Node.js server
RewriteRule ^api/(.*)$ http://127.0.0.1:3001/api/$1 [P,L]
RewriteRule ^uploads/(.*)$ http://127.0.0.1:3001/uploads/$1 [P,L]

# Serve static files from dist/
RewriteRule ^(assets/.*)$ dist/$1 [L]
RewriteRule ^(favicon\.svg|icons\.svg)$ dist/$1 [L]

# SPA fallback — serve dist/index.html for all other routes
RewriteCond %{REQUEST_URI} !^/dist/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . dist/index.html [L]
